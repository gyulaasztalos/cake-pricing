{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automergeSchedule": [
    "after 5am every weekday",
    "before 4pm every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Budapest",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["pep621", "pip_requirements", "dockerfile", "github-actions"],
      "enabled": true
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies", "dev"],
      "automerge": true
    }
  ],
  "platformAutomerge": true
}
